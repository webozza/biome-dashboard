# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# firebase service account keys — NEVER commit
*-firebase-adminsdk-*.json
project-v-*.json
google-services.json
GoogleService-Info.plist

# lockfile (project uses pnpm — ignore npm's lockfile)
package-lock.json

# firebase CLI artifacts
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# editors
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
ehthumbs.db

# misc
*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
